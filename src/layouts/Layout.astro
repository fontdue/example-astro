---
import 'fontdue-js/fontdue.css';
import { loadFontdueProviderQuery } from 'fontdue-js';
import FontdueProvider from 'fontdue-js/FontdueProvider';
import StoreModal from 'fontdue-js/StoreModal';
import CartButton, { loadCartButtonQuery } from 'fontdue-js/CartButton';

interface Props {
  title?: string;
}

const { title = 'fontdue-js on Astro' } = Astro.props;

// Layout-level preloads: theme custom properties + cart count, fetched once
// per request. The FontdueProvider commits the aux-UI payload into the client
// Relay env on hydration; CartButton receives its own preloadedQuery so the
// header reflects current cart state on first paint.
const [fontduePreload, cartPreload] = await Promise.all([
  loadFontdueProviderQuery(),
  loadCartButtonQuery(),
]);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style is:global>
      body { font-family: system-ui, sans-serif; margin: 0; }
      main { max-width: 960px; margin: 0 auto; padding: 2rem; }
      h1 { font-size: 1.5rem; margin-bottom: 1rem; }
      h2 { font-size: 1.125rem; margin-top: 2.5rem; margin-bottom: 0.75rem; }
      .tester { margin-top: 1.5rem; border: 1px solid #eee; padding: 1rem; }
      .site-header {
        position: sticky;
        top: 0;
        background: white;
        border-bottom: 1px solid #eee;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        z-index: 10;
      }
      .site-header__nav { display: flex; gap: 1rem; }
      .site-header__nav a { color: #333; text-decoration: none; }
      .site-header__nav a:hover { text-decoration: underline; }
      .site-header__cart .cart-button { all: unset; cursor: pointer; padding: 0.25rem 0.5rem; }
      .site-header__cart .cart-button[data-active='true'] {
        background: #111; color: white; border-radius: 0.25rem;
      }
    </style>
  </head>
  <body>
    <FontdueProvider client:load preloadedQuery={fontduePreload} />
    <StoreModal client:load />
    <header class="site-header">
      <nav class="site-header__nav">
        <a href="/">Home</a>
        <a href="/fonts/ibm-plex">IBM Plex</a>
        <a href="/fonts/rubik">Rubik</a>
        <a href="/test-fonts">Test fonts</a>
      </nav>
      <div class="site-header__cart">
        <CartButton client:load preloadedQuery={cartPreload} suffix=" ({count})" />
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
